# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autoflow

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SendGrid (REQUIRED for email functionality)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@autoflow.com
SENDGRID_FROM_NAME=AutoFlow

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Sentry (monitoring - optional)
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Fakturownia
FAKTUROWNIA_API_TOKEN=your_fakturownia_api_token
FAKTUROWNIA_ACCOUNT=your_account_name

# Google APIs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Outlook IMAP
OUTLOOK_EMAIL=your_outlook_email
OUTLOOK_PASSWORD=your_outlook_password
OUTLOOK_IMAP_SERVER=outlook.office365.com
OUTLOOK_IMAP_PORT=993

# Application
APP_NAME=AutoFlow
APP_VERSION=1.0.0
DEBUG=True
